# Traject Backend — Environment Configuration
# Copy this file to deploy/.env (or the working directory) and adjust values.
# Variables marked REQUIRED have no safe default and must be set before
# `docker compose up` will start (compose fails fast if they are missing).

# ---------------------------------------------------------------------------
# Database (PostgreSQL 16 + pgvector)
# ---------------------------------------------------------------------------

# REQUIRED — Postgres credentials. Do NOT reuse the old axon/axon defaults.
# These are consumed by both the postgres service and DATABASE_URL below.
POSTGRES_USER=traject
# REQUIRED — use a strong, randomly generated password (e.g. `openssl rand -hex 24`).
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=traject

# Full async SQLAlchemy connection URL.
# Format: postgresql+asyncpg://<user>:<password>@<host>:<port>/<dbname>
# For docker-compose this is derived from the POSTGRES_* vars above; set it
# explicitly only if you run the backend outside compose.
DATABASE_URL=postgresql+asyncpg://traject:CHANGE_ME_STRONG_PASSWORD@localhost:5432/traject

# Number of persistent connections kept open in the connection pool.
DATABASE_POOL_SIZE=10

# Additional connections that can be created beyond DATABASE_POOL_SIZE
# under burst load. Total max = DATABASE_POOL_SIZE + DATABASE_MAX_OVERFLOW.
DATABASE_MAX_OVERFLOW=20

# ---------------------------------------------------------------------------
# Redis 7
# ---------------------------------------------------------------------------

# REQUIRED — Redis now runs with `--requirepass`, so a password is mandatory.
# Use a strong, randomly generated value (e.g. `openssl rand -hex 24`).
REDIS_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Redis connection URL. Note the password component (redis://:<password>@host).
# For docker-compose this is derived from REDIS_PASSWORD; set it explicitly
# only if you run the backend outside compose.
REDIS_URL=redis://:CHANGE_ME_STRONG_PASSWORD@localhost:6379/0

# Default TTL (in seconds) for values cached in Redis.
# Default: 86400 = 24 hours.
REDIS_CACHE_TTL_SECONDS=86400

# ---------------------------------------------------------------------------
# API server (Uvicorn)
# ---------------------------------------------------------------------------

# Host address Uvicorn binds to. Use 0.0.0.0 to accept all interfaces.
API_HOST=0.0.0.0

# Port Uvicorn listens on.
API_PORT=8000

# Number of Uvicorn worker processes. Set to 1 for local development.
API_WORKERS=2

# Comma-separated list of origins allowed by the CORS middleware.
# In pydantic-settings, list fields can be set as a JSON array string:
#   CORS_ORIGINS='["http://localhost:3000","https://app.example.com"]'
CORS_ORIGINS=["http://localhost:3000"]

# ---------------------------------------------------------------------------
# Security — API key authentication
# ---------------------------------------------------------------------------

# Name of the HTTP request header that carries the API key.
API_KEY_HEADER=X-Traject-API-Key

# REQUIRED — secret value clients must supply in the API_KEY_HEADER header.
# The backend REFUSES TO START if this is left at the placeholder default, so
# set a strong unique value (e.g. `openssl rand -hex 32`) before running.
# Consumed by docker-compose as TRAJECT_API_KEY (passed to the backend's API_KEY).
TRAJECT_API_KEY=CHANGE_ME_API_KEY
API_KEY=CHANGE_ME_API_KEY

# ---------------------------------------------------------------------------
# Semantic cache
# ---------------------------------------------------------------------------

# Minimum cosine similarity (0.0–1.0) required to count a pgvector
# nearest-neighbour result as a cache hit.
CACHE_SIMILARITY_THRESHOLD=0.92

# Maximum number of entries retained in the cache_entries table.
# Entries beyond this limit are evicted by the daily cleanup worker.
CACHE_MAX_ENTRIES=100000

# ---------------------------------------------------------------------------
# Budget alerts
# ---------------------------------------------------------------------------

# HTTP request timeout (in seconds) when posting to a budget-alert webhook.
BUDGET_ALERT_WEBHOOK_TIMEOUT_SECONDS=10

# ---------------------------------------------------------------------------
# Grafana (used by docker-compose only — not read by traject-backend)
# ---------------------------------------------------------------------------

# REQUIRED — admin password for the Grafana UI. There is no longer a weak
# `admin` default; compose fails to start if this is unset.
GRAFANA_PASSWORD=CHANGE_ME_STRONG_PASSWORD
